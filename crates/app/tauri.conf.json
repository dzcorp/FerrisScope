{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FerrisScope",
  "mainBinaryName": "ferrisscope",
  "version": "1.0.0",
  "identifier": "dev.ferrisscope.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "FerrisScope",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Rust-native Kubernetes IDE",
    "longDescription": "An open-source Kubernetes desktop IDE written in Rust + Tauri."
  }
}
